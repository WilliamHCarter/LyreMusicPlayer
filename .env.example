# Spotify app credentials (https://developer.spotify.com/dashboard).
# WARNING: PUBLIC_ vars are embedded in the built client bundle -- they are
# visible to anyone who loads the site. The client_credentials flow here only
# powers the public album wall; user auth uses PKCE and needs no secret.
PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id
PUBLIC_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
